#!/usr/bin/env python3
r"""
Agentic LangGraph safety pipeline -- Zomato delivery-partner edition.

What makes this TRULY AGENTIC (vs the original fixed pipeline):
  1. The agent has TOOLS it can call dynamically (policy_lookup, escalation_drafter,
     incentive_calculator, rating_advisor).
  2. The agent REASONS about which tools to invoke based on the question — it is
     not pre-wired to always call the same sequence.
  3. A ReAct loop (Reason → Act → Observe → Reason…) runs until the agent
     decides it has enough information to answer.
  4. The safety guardrail sits OUTSIDE the agent loop and judges the final
     answer, not individual tool calls.
  5. Memory: conversation history is carried across turns within a session.

Flow:
  user question
    -> input_guardrail (DENY -> canned refusal)
    -> agent loop (ReAct: picks tools, reasons, iterates)
         tool: policy_lookup        -- answers policy/rule questions
         tool: incentive_calculator -- computes weekly earnings
         tool: escalation_drafter   -- drafts support escalation text
         tool: rating_advisor       -- advice on protecting ratings
    -> output_guardrail (DENY -> blocked)
    -> deliver final_response

Deps:
  pip install langgraph langchain-ollama langchain-core

Usage:
  python3 agentic_zomato_pipeline.py --runs 3
  python3 agentic_zomato_pipeline.py --runs 1 --print-answers
"""

import argparse
import json
import operator
import re
import statistics
import sys
import time
from collections import Counter, defaultdict
from datetime import datetime, timezone
from typing import Annotated, TypedDict, Literal

from langchain_core.messages import (
    AIMessage, BaseMessage, HumanMessage, SystemMessage, ToolMessage
)
from langchain_core.tools import tool
from langchain_ollama import ChatOllama
from langgraph.graph import StateGraph, END
from langgraph.prebuilt import ToolNode

# ─────────────────────────── KNOWLEDGE BASE ───────────────────────────────────

CONTEXT = (
    "Zomato Delivery Partner Guide (summary):\n"
    "Earnings: partners earn a base pay per delivered order plus distance pay "
    "per km beyond 4 km. Surge pay applies during rain and peak dinner hours "
