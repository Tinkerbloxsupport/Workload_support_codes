# ─────────────────────────── OUTCOME / REPORTING ──────────────────────────────

def outcome_of(metrics_list):
    stages = {m["stage"]: m for m in metrics_list}
    if stages.get("input_gate", {}).get("verdict") == "DENY":
        return "refused_input"
    og = stages.get("output_gate")
    if og and og.get("verdict") == "DENY":
        return "blocked_output"
    return "delivered"


def main():
    ap = argparse.ArgumentParser(
        description="Agentic Zomato safety pipeline benchmark (LangGraph ReAct)")
    ap.add_argument("--url",              default="http://localhost:11434")
    ap.add_argument("--safeguard-model",  default="gpt-oss-safeguard:latest")
    ap.add_argument("--gen-model",        default="llama3:8b")
    ap.add_argument("--runs",             type=int, default=3)
    ap.add_argument("--gate-num-predict", type=int, default=256)
    ap.add_argument("--gen-num-predict",  type=int, default=1024)
    ap.add_argument("--keep-alive",       default="30m")
    ap.add_argument("--out",              default="agentic_results.jsonl")
    ap.add_argument("--responses-out",    default="agentic_responses.jsonl")
    ap.add_argument("--print-answers",    action="store_true")
    args = ap.parse_args()

    # ── Warmup ────────────────────────────────────────────────────────────────
    for m in (args.safeguard_model, args.gen_model):
        print(f"--- warmup {m} ---", flush=True)
        try:
            ChatOllama(model=m, base_url=args.url, keep_alive=args.keep_alive,
                       num_predict=4, temperature=0).invoke("ok")
        except Exception as e:
            print(f"warmup FAILED for {m}: {e}", file=sys.stderr)
            sys.exit(1)

    app = build_app(args)
    results = []

    with open(args.out, "a") as fh, open(args.responses_out, "a") as rf:
        for scenario in SCENARIOS:
            for run in range(1, args.runs + 1):
                t0 = time.perf_counter()
                start_iso = now_iso()
                try:
                    final = app.invoke(
                        {
                            "messages": [HumanMessage(content=scenario["user_msg"])],
                            "tool_calls_made": [],
                        }
                    )
                except Exception as e:
                    err = {"scenario": scenario["name"], "run": run, "error": str(e)}
                    print(f"{scenario['name']} run{run} ERROR: {e}", file=sys.stderr)
                    fh.write(json.dumps(err) + "\n")
                    fh.flush()
                    continue

                e2e = round(time.perf_counter() - t0, 3)
                metrics = final.get("stage_metrics", [])
                outcome = outcome_of(metrics)
                tools_used = final.get("tool_calls_made", [])
                final_resp = final.get("final_response", "")

                rec = {
                    "scenario": scenario["name"],
                    "expected_input_verdict": scenario["expected"],
                    "start_time": start_iso,
                    "end_time": now_iso(),
                    "run": run,
                    "outcome": outcome,
                    "e2e_wall_s": e2e,
                    "tools_used": tools_used,
                    "agent_reasoning_steps": sum(
                        1 for m in metrics if m["stage"] == "agent_reason"),
                    "final_response_preview": final_resp[:160],
                    "stage_metrics": metrics,
                }
                results.append(rec)
                fh.write(json.dumps(rec) + "\n")
                fh.flush()
                rf.write(json.dumps({
                    "scenario": rec["scenario"],
                    "run": run,
                    "outcome": outcome,
                    "tools_used": tools_used,
                    "final_response": final_resp,
                }) + "\n")
                rf.flush()

                # Gate verdict for display
                gate_m = next((m for m in metrics if m["stage"] == "input_gate"), {})
                verdict = gate_m.get("verdict", "?")
                mark = "" if verdict == scenario["expected"] else " !MISMATCH"

                print(
                    f"{scenario['name']:<22} run{run}  "
                    f"in={verdict}  tools={tools_used}  "
                    f"steps={rec['agent_reasoning_steps']}  "
                    f"-> {outcome}  e2e={e2e}s{mark}",
                    flush=True,
                )
                if args.print_answers:
                    print(f"    ANSWER: {final_resp[:300]}\n", flush=True)

    if not results:
        print("no successful runs", file=sys.stderr)
        sys.exit(1)

    # ── Summary ───────────────────────────────────────────────────────────────
    print("\n=== OUTCOMES ===")
    by_scen = defaultdict(list)
    for r in results:
        by_scen[r["scenario"]].append(r)
    print(f"{'scenario':<22} {'outcomes':<24} {'mean_e2e_s':>10} {'mean_steps':>10}")
    for scen, recs in by_scen.items():
        oc = ",".join(f"{k}:{v}" for k, v in
                      Counter(r["outcome"] for r in recs).items())
        print(f"{scen:<22} {oc:<24} "
              f"{mean([r['e2e_wall_s'] for r in recs]):>10.1f} "
              f"{mean([r['agent_reasoning_steps'] for r in recs]):>10.1f}")

    print("\n=== TOOL USAGE ===")
    all_tools = [t for r in results for t in r["tools_used"]]
    for tname, cnt in Counter(all_tools).most_common():
        print(f"  {tname:<25} used {cnt}x across all runs")
    print(f"  avg tools per delivered request: "
          f"{mean([len(r['tools_used']) for r in results if r['outcome'] == 'delivered']):.1f}")

    print("\n=== WHAT MAKES THIS AGENTIC ===")
    print("  ✓ LLM bound to tools — it CHOOSES which tools to call")
    print("  ✓ ReAct loop: Reason → Act (tool) → Observe → Reason again")
    print("  ✓ Multi-tool chaining: agent can call policy_lookup THEN")
    print("    incentive_calculator THEN escalation_drafter in one request")
    print("  ✓ Dynamic routing: graph path depends on LLM tool-call decisions")
    print("  ✓ Safety guardrail sits outside the loop, judges final output only")


if __name__ == "__main__":
    main()
